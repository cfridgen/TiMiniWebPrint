  "runtime.replacements": [
    { "pattern": "\\[connected\\]", "replacement": "[verbunden]", "flags": "g" },
    { "pattern": "^Ready\\.$", "replacement": "Bereit.", "flags": "u" },
    { "pattern": "^Not connected\\.$", "replacement": "Nicht verbunden.", "flags": "u" },
    { "pattern": "^Scanning for printers\\.\\.\\.$", "replacement": "Suche nach Druckern...", "flags": "u" },
    { "pattern": "^Scan failed\\.$", "replacement": "Scan fehlgeschlagen.", "flags": "u" },
    { "pattern": "^No supported printers found\\.$", "replacement": "Keine unterstützten Drucker gefunden.", "flags": "u" },
    { "pattern": "^No printer selected\\.$", "replacement": "Kein Drucker ausgewählt.", "flags": "u" },
    { "pattern": "^Auto-connecting\\.\\.\\.$", "replacement": "Automatische Verbindung...", "flags": "u" },
    { "pattern": "^Connecting\\.\\.\\.$", "replacement": "Verbinde...", "flags": "u" },
    { "pattern": "^Connecting selected printer\\.\\.\\.$", "replacement": "Ausgewählter Drucker wird verbunden...", "flags": "u" },
    { "pattern": "^Scanning \\/ connecting printer…$", "replacement": "Drucker wird gesucht / verbunden…", "flags": "u" },
    { "pattern": "^Printing\\.\\.\\.$", "replacement": "Drucke...", "flags": "u" },
    { "pattern": "^Print already in progress\\.$", "replacement": "Druck läuft bereits.", "flags": "u" },
    { "pattern": "^Print request cancelled\\. Printer may continue if it already started\\.$", "replacement": "Druckanfrage abgebrochen. Der Drucker kann weiterdrucken, wenn bereits gestartet.", "flags": "u" },
    { "pattern": "^Cancelling print request\\.\\.\\.$", "replacement": "Druckanfrage wird abgebrochen...", "flags": "u" },
    { "pattern": "^No debug entries yet\\.$", "replacement": "Noch keine Debug-Einträge.", "flags": "u" },
    { "pattern": "^No debug entries\\.$", "replacement": "Keine Debug-Einträge.", "flags": "u" },
    { "pattern": "^Loading debug log\\.\\.\\.$", "replacement": "Debug-Log wird geladen...", "flags": "u" },
    { "pattern": "^Connected: (.+)$", "replacement": "Verbunden: $1", "flags": "u" },
    { "pattern": "^Connected to (.+)\\.$", "replacement": "Verbunden mit $1.", "flags": "u" },
    { "pattern": "^Using active printer: (.+)\\.$", "replacement": "Aktiver Drucker wird verwendet: $1.", "flags": "u" },
    { "pattern": "^Auto-connecting first detected printer\\.\\.\\.$", "replacement": "Erster gefundener Drucker wird automatisch verbunden...", "flags": "u" },
    { "pattern": "^Printer detected\\. Auto-connect failed, please click Connect\\.$", "replacement": "Drucker erkannt. Auto-Verbindung fehlgeschlagen, bitte auf Verbinden klicken.", "flags": "u" },
    { "pattern": "^Scan failed: (.+)$", "replacement": "Scan fehlgeschlagen: $1", "flags": "u" },
    { "pattern": "^Connect failed: (.+)$", "replacement": "Verbindung fehlgeschlagen: $1", "flags": "u" },
    { "pattern": "^Preview failed: (.+)$", "replacement": "Vorschau fehlgeschlagen: $1", "flags": "u" },
    { "pattern": "^Preview ready \\((.+)\\)\\.$", "replacement": "Vorschau bereit ($1).", "flags": "u" },
    { "pattern": "^Print failed: (.+)$", "replacement": "Drucken fehlgeschlagen: $1", "flags": "u" },
    { "pattern": "^Scan warning \\[(.+)\\]: (.+)$", "replacement": "Scan-Warnung [$1]: $2", "flags": "u" },
    { "pattern": "^Scan hint \\[(.+)\\]: (.+)$", "replacement": "Scan-Hinweis [$1]: $2", "flags": "u" },
    { "pattern": "^Scan details \\[(.+)\\]: (.+)$", "replacement": "Scan-Details [$1]: $2", "flags": "u" },
    { "pattern": "^Debug clear failed: (.+)$", "replacement": "Debug-Leeren fehlgeschlagen: $1", "flags": "u" },
    { "pattern": "^Debug log failed: (.+)$", "replacement": "Debug-Log fehlgeschlagen: $1", "flags": "u" },
    { "pattern": "^Debug log cleared\\.$", "replacement": "Debug-Log geleert.", "flags": "u" }
  ]
}