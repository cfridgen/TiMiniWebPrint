  "runtime.replacements": [
    { "pattern": "\\[connected\\]", "replacement": "[connected]", "flags": "g" },
    { "pattern": "^Ready\\.$", "replacement": "Ready.", "flags": "u" },
    { "pattern": "^Not connected\\.$", "replacement": "Not connected.", "flags": "u" },
    { "pattern": "^Scanning for printers\\.\\.\\.$", "replacement": "Scanning for printers...", "flags": "u" },
    { "pattern": "^Scan failed\\.$", "replacement": "Scan failed.", "flags": "u" },
    { "pattern": "^No supported printers found\\.$", "replacement": "No supported printers found.", "flags": "u" },
    { "pattern": "^No printer selected\\.$", "replacement": "No printer selected.", "flags": "u" },
    { "pattern": "^Auto-connecting\\.\\.\\.$", "replacement": "Auto-connecting...", "flags": "u" },
    { "pattern": "^Connecting\\.\\.\\.$", "replacement": "Connecting...", "flags": "u" },
    { "pattern": "^Connecting selected printer\\.\\.\\.$", "replacement": "Connecting selected printer...", "flags": "u" },
    { "pattern": "^Scanning \\/ connecting printer…$", "replacement": "Scanning / connecting printer…", "flags": "u" },
    { "pattern": "^Printing\\.\\.\\.$", "replacement": "Printing...", "flags": "u" },
    { "pattern": "^Print already in progress\\.$", "replacement": "Print already in progress.", "flags": "u" },
    { "pattern": "^Print request cancelled\\. Printer may continue if it already started\\.$", "replacement": "Print request cancelled. Printer may continue if it already started.", "flags": "u" },
    { "pattern": "^Cancelling print request\\.\\.\\.$", "replacement": "Cancelling print request...", "flags": "u" },
    { "pattern": "^No debug entries yet\\.$", "replacement": "No debug entries yet.", "flags": "u" },
    { "pattern": "^No debug entries\\.$", "replacement": "No debug entries.", "flags": "u" },
    { "pattern": "^Loading debug log\\.\\.\\.$", "replacement": "Loading debug log...", "flags": "u" },
    { "pattern": "^Connected: (.+)$", "replacement": "Connected: $1", "flags": "u" },
    { "pattern": "^Connected to (.+)\\.$", "replacement": "Connected to $1.", "flags": "u" },
    { "pattern": "^Using active printer: (.+)\\.$", "replacement": "Using active printer: $1.", "flags": "u" },
    { "pattern": "^Auto-connecting first detected printer\\.\\.\\.$", "replacement": "Auto-connecting first detected printer...", "flags": "u" },
    { "pattern": "^Printer detected\\. Auto-connect failed, please click Connect\\.$", "replacement": "Printer detected. Auto-connect failed, please click Connect.", "flags": "u" },
    { "pattern": "^Scan failed: (.+)$", "replacement": "Scan failed: $1", "flags": "u" },
    { "pattern": "^Connect failed: (.+)$", "replacement": "Connect failed: $1", "flags": "u" },
    { "pattern": "^Preview failed: (.+)$", "replacement": "Preview failed: $1", "flags": "u" },
    { "pattern": "^Preview ready \\((.+)\\)\\.$", "replacement": "Preview ready ($1).", "flags": "u" },
    { "pattern": "^Print failed: (.+)$", "replacement": "Print failed: $1", "flags": "u" },
    { "pattern": "^Scan warning \\[(.+)\\]: (.+)$", "replacement": "Scan warning [$1]: $2", "flags": "u" },
    { "pattern": "^Scan hint \\[(.+)\\]: (.+)$", "replacement": "Scan hint [$1]: $2", "flags": "u" },
    { "pattern": "^Scan details \\[(.+)\\]: (.+)$", "replacement": "Scan details [$1]: $2", "flags": "u" },
    { "pattern": "^Debug clear failed: (.+)$", "replacement": "Debug clear failed: $1", "flags": "u" },
    { "pattern": "^Debug log failed: (.+)$", "replacement": "Debug log failed: $1", "flags": "u" },
    { "pattern": "^Debug log cleared\\.$", "replacement": "Debug log cleared.", "flags": "u" }
  ]
}